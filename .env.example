# Kakao Maps JavaScript API key — in-panel Navigation app (map + place search)
# Get from https://developers.kakao.com → [내 애플리케이션] → [앱 키] → JavaScript 키
# Register your dev (localhost) domain in [플랫폼] → Web.
# Leave blank to show a fallback notice in the map view.
VITE_KAKAO_JS_KEY=your_kakao_js_app_key_here

# Gemini API key(s) for the keyboard-chat searchbox in VehicleHMI.
# Multiple keys allowed (comma- or newline-separated) — the client round-robins
# past 429/503 quota errors so you don't have to rotate manually.
# Get from https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEYS=your_gemini_api_key_here

# Google Cloud Text-to-Speech key. Used to read the per-sequence AutopilotStatus
# + zoom-in + zoom-out aloud (voice-only — these lines never become chat bubbles).
# Get from https://console.cloud.google.com → APIs & Services → Credentials.
# Enable the "Cloud Text-to-Speech API" on the same project.
VITE_GOOGLE_TTS_API_KEY=your_google_tts_api_key_here
